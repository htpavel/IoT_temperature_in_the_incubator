    {
        "id": "72682f43c0053b14",
        "type": "function",
        "z": "2c41a2bd.aa36ae",
        "name": "prepare Insert",
        "func": "// 1. Získání ID zařízení z MQTT topiku\n// Očekávaný formát topiku: node/8492c4231234/thermometer/0:0/temperature\nvar topicParts = msg.topic.split('/');\nvar deviceId = topicParts[1] || \"unknown\"; // Pokud by topik selhal, zapíše \"unknown\"\n\n// 2. Základní proměnné\nvar input = msg.payload;\nvar temperature = parseFloat(input);\nvar statusMsg = \"OK\";\nvar type = \"data\";\n\n// 3. DETEKCE CHYBY 1: Výpadek vysílání (Watchdog)\nif (isNaN(temperature)) {\n    type = \"error\";\n    statusMsg = \"Vypadek vysilani / Napajeni\";\n    temperature = null;\n} else {\n    // 4. DETEKCE CHYBY 2: Slabá baterie\n    var lastBat = flow.get(\"last_voltage\") || 3.3;\n\n    if (lastBat < 2.4) {\n        statusMsg = \"Slabá baterie (\" + lastBat.toFixed(2) + \"V)\";\n    }\n}\n\n// 5. Příprava časového razítka\nvar localTimestamp = new Date().toLocaleString(\"sv-SE\", { timeZone: \"Europe/Prague\" });\n\n// 6. Příprava SQL dotazu (PŘIDÁNO nodeId)\nmsg.topic = `INSERT INTO measurements (timestamp, nodeId, type, temperature, message, is_sent) \n             VALUES ('${localTimestamp}', '${deviceId}', '${type}', ${temperature === null ? 'NULL' : temperature}, '${statusMsg}', 0);`;\n\n// 7. Vizuální status v Node-RED\nif (type === \"error\") {\n    node.status({ fill: \"red\", shape: \"dot\", text: statusMsg });\n} else if (statusMsg.includes(\"baterie\")) {\n    node.status({ fill: \"yellow\", shape: \"dot\", text: statusMsg });\n} else {\n    var voltInfo = flow.get(\"last_voltage\") ? flow.get(\"last_voltage\").toFixed(2) + \"V\" : \"N/A\";\n    node.status({ fill: \"green\", shape: \"dot\", text: \"ID: \" + deviceId + \" | \" + temperature + \"°C (\" + voltInfo + \")\" });\n}\n\nreturn msg;",
        "outputs": 1,
        "timeout": "",
        "noerr": 0,
        "initialize": "",
        "finalize": "",
        "libs": [],
        "x": 680,
        "y": 200,
        "wires": [
            [
                "6c98872225052be8"
            ]
        ]
    },
