    {
        "id": "ddf4d9ad945b3a09",
        "type": "function",
        "z": "2c41a2bd.aa36ae",
        "name": "check timeout",
        "func": "// Dotaz vybere poslední timestamp z tabulky\nmsg.topic = \"SELECT timestamp FROM measurements ORDER BY timestamp DESC LIMIT 1;\";\nreturn msg;",
        "outputs": 1,
        "timeout": 0,
        "noerr": 0,
        "initialize": "",
        "finalize": "",
        "libs": [],
        "x": 320,
