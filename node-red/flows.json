        ]
    },
    {
        "id": "94b7899634daae38",
        "type": "function",
        "z": "2c41a2bd.aa36ae",
        "name": "evaluate timeout",
        "func": "if (!msg.payload || msg.payload.length === 0) {\n    node.status({ fill: \"red\", shape: \"ring\", text: \"Databáze je prázdná\" });\n    return null;\n}\n\n// 1. Získání času z DB a převod na objekt Date\n// msg.payload[0].timestamp je např. \"2026-03-27 20:15:00\"\nvar lastSeen = new Date(msg.payload[0].timestamp);\n\n// 2. Aktuální čas\nvar now = new Date();\n\n// 3. Výpočet rozdílu v milisekundách a převod na minuty\n// getTime() zajistí, že odčítáme čísla (timestampy)\nvar diffMs = now.getTime() - lastSeen.getTime();\nvar diffMinutes = diffMs / (1000 * 60);\n\n// DEBUG do statusu (uvidíš, kolik minut to napočítalo)\nnode.status({ fill: \"blue\", shape: \"dot\", text: \"Prodleva: \" + Math.round(diffMinutes) + \" min\" });\n\n// 4. Podmínka pro chybu (15 minut)\nif (diffMinutes > 15) {\n    var localTimestamp = now.toLocaleString(\"sv-SE\", { timeZone: \"Europe/Prague\" });\n\n    msg.topic = `INSERT INTO measurements (timestamp, type, temperature, message, is_sent) \n                 VALUES ('${localTimestamp}', 'error', NULL, 'Senzor offline', 0);`;\n    return msg;\n}\n\nreturn null; // Vše je v pořádku",
        "outputs": 1,
        "timeout": 0,
        "noerr": 0,
        "initialize": "",
        "finalize": "",
        "libs": [],
        "x": 680,
        "y": 560,
        "wires": [
            [
                "9773a6bb38bae4bf"
            ]
        ]
    },
