        "id": "18da10ca137142f7",
        "type": "function",
        "z": "2c41a2bd.aa36ae",
        "name": "prepare DELETE",
        "func": "// 1. SQL příkaz pro promazání starých a odeslaných dat\n// Používáme 'localtime', aby se čas 'now' shodoval s tvým nastavením v ČR\nmsg.topic = \"DELETE FROM measurements WHERE is_sent = 1 AND timestamp <= datetime('now', '-24 hours', 'localtime');\";\n\n// 2. Status pro vizuální kontrolu v Node-RED\nnode.status({fill:\"blue\", shape:\"ring\", text:\"Provádím úklid databáze...\"});\n\n// 3. Vyčištění payloadu\nmsg.payload = [];\n\nreturn msg;",
