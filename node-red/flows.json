                "0e892e0ece20052e"
            ]
        ]
    },
    {
        "id": "96e79716d7f07c1f",
        "type": "comment",
        "z": "2c41a2bd.aa36ae",
        "name": "Větev 3 - Odeslání na cloud",
        "info": "každých 15 minut\nnajde položky v DB, které mají status: \"new\"\npřipravý na odeslání - Je nastaven limit na 200, abych nezahltil server na BE.\npošle na cloud\n a) vrátí 200\n    zapíše status do lokální DB status: \"sent\"\n b) vrátí chybu\n    nic nezapisuje\n",
        "x": 1400,
        "y": 220,
        "wires": []
    },
    {
        "id": "74adafc15c44af3a",
        "type": "function",
        "z": "2c41a2bd.aa36ae",
        "name": "prepare FIND \"not sent\"",
        "func": "// 1. Definujeme SQL dotaz pro neodeslaná data\n// Is_sent = 0 znamená, že data jsou v lokální DB, ale ještě ne na cloudu\nmsg.topic = \"SELECT * FROM measurements WHERE is_sent = 0 ORDER BY id ASC LIMIT 200;\";\n\n// 2. Dočasně uložíme informaci pro status (volitelné)\n// SQLite uzel po provedení tohoto dotazu vrátí pole v msg.payload.\n// Abychom věděli, co se děje teď, nastavíme \"přípravný\" status:\nnode.status({fill:\"blue\", shape:\"ring\", text:\"Dotazuji neodeslaná data...\"});\n\nreturn msg;",
        "outputs": 1,
        "timeout": "",
        "noerr": 0,
        "initialize": "",
        "finalize": "",
        "libs": [],
        "x": 390,
        "y": 360,
        "wires": [
