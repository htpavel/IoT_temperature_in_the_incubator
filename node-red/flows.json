    {
        "id": "12dcce1ff89dbf87",
        "type": "function",
        "z": "2c41a2bd.aa36ae",
        "name": "create table",
        "func": "// 1. SQL příkaz pro vytvoření tabulky (PŘIDÁNO nodeId)\nmsg.topic = `CREATE TABLE IF NOT EXISTS measurements (\n    id INTEGER PRIMARY KEY AUTOINCREMENT,\n    nodeId TEXT,                 -- Unikátní ID/Alias stanice (např. core-incubator)\n    timestamp DATETIME DEFAULT CURRENT_TIMESTAMP,\n    type TEXT DEFAULT 'data',    -- 'data' nebo 'error'\n    temperature REAL,            -- Naměřená teplota\n    message TEXT,                -- Detailní stav (např. o baterii)\n    is_sent INTEGER DEFAULT 0    -- 0 = čeká na odeslání, 1 = odesláno\n);`;\n\n// 2. Nastavení payloadu na prázdné pole (podle tvého požadavku)\nmsg.payload = [];\n\n// Vizuální status pro Node-RED\nnode.status({ fill: \"blue\", shape: \"ring\", text: \"Inicializace tabulky...\" });\n\nreturn msg;",
