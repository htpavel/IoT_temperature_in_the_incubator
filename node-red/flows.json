            ]
        ]
    },
    {
        "id": "aaf3b997499c1bb1",
        "type": "comment",
        "z": "2c41a2bd.aa36ae",
        "name": "Větev 1 - Čtení dat z Controlleru a uložení do local DB",
        "info": "Načte data\nZobrazí data v grafu\nZobrazí data v tachografu\nzobrazí data jako text, kde hlídá,jestli je teplota v rozmezí. \ntrigger - pokud nepřijde zpráva 10 minut, upozorní na offline teploměru.\nsmooth - průměruje teploty podle posledních 30 hodnot\ndelay - vezme zprávy pouze každou minutu. Z důvodu šetření databáze.\nvloží data do lokální sqlite DB",
        "x": 1480,
        "y": 100,
        "wires": []
    },
