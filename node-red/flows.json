    {
        "id": "b51b8c569c23515b",
        "type": "function",
        "z": "2c41a2bd.aa36ae",
        "name": "prepare POST",
        "func": "// 1. Kontrola, zda máme data z DB\nif (!msg.payload || msg.payload.length === 0) {\n    node.status({ fill: \"gray\", shape: \"ring\", text: \"Žádná nová data\" });\n    return null;\n}\n\n// 2. Záloha pro následný UPDATE (is_sent = 1)\nmsg.records = msg.payload;\n\n// 3. Nastavení URL a hlaviček podle specifikace\nmsg.url = \"https://hatchery-l9qw.onrender.com/api/data\";\nmsg.method = \"POST\";\nmsg.headers = {\n    \"Content-Type\": \"application/json\",\n    \"x-api-key\": \"hatchery-gw-key-2026\",\n    \"x-gateway-id\": \"gateway-01\"\n};\n\n// 4. Transformace dat do požadovaného formátu\n// Přidali jsme nodeId, aby cloud mohl data filtrovat podle staničky\nmsg.payload = msg.records.map(row => {\n    return {\n        id: row.id,            // ID v lokální DB (pro zpětné potvrzení)\n        nodeId: row.stationId,    \n        temp: row.temperature,\n        time: row.timestamp,\n        msg: row.message\n    };\n});\n\nnode.status({ fill: \"blue\", shape: \"dot\", text: \"Odesílám \" + msg.payload.length + \" záznamů\" });\n\nreturn msg;",
        "outputs": 1,
        "timeout": "",
        "noerr": 0,
        "initialize": "",
        "finalize": "",
        "libs": [],
        "x": 780,
        "y": 400,
        "wires": [
            [
                "0ba44c0156d3e28e"
            ]
        ]
    },
    {
        "id": "7ec5f0b3ffb28974",
        "type": "comment",
        "z": "2c41a2bd.aa36ae",
        "name": "Větev 4 - Smazání dat starších 24 hodin",
        "info": "Spouští se ve 00:00\nSmaže data, která mají status \"sent\" (poslána na express) a jsou starší jak 24 hodin.",
        "x": 1430,
        "y": 280,
        "wires": []
    },
    {
        "id": "631cf0c5df90a253",
        "type": "function",
        "z": "2c41a2bd.aa36ae",
        "name": "data sent",
        "func": "// Kontrola, zda server přijal data (stav 200 nebo 201)\nif (msg.statusCode === 200 || msg.statusCode === 201) {\n    // Tento příkaz označí záznamy za vyřízené\n    msg.topic = \"UPDATE measurements SET is_sent = 1 WHERE rowid IN (SELECT rowid FROM measurements WHERE is_sent = 0 LIMIT 200);\";\n    return msg;\n} else {\n    // Pokud server vrátil chybu (např. 500), nic neoznačujeme a zkusíme to příště\n    node.error(\"Server error: \" + msg.statusCode);\n    return null;\n}",
        "outputs": 1,
        "timeout": "",
        "noerr": 0,
        "initialize": "",
        "finalize": "",
        "libs": [],
        "x": 1140,
        "y": 440,
        "wires": [
