    {
        "id": "8fd85b18eb406ee6",
        "type": "function",
        "z": "2c41a2bd.aa36ae",
        "name": "prepare battery status",
        "func": "var voltage = parseFloat(msg.payload);\n\nif (isNaN(voltage)) return null;\n\n// Uložíme napětí do paměti flow, aby si ho mohl přečíst uzel prepare Insert\nflow.set(\"last_voltage\", voltage);\n\n// Příprava textu pro uzel \"battery state\" (Dashboard)\nmsg.payload = voltage.toFixed(2) + \" V\";\n\nreturn msg;",
